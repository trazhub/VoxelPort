{
  "name": "voxelport",
  "version": "1.0.0",
  "description": "Electron + React desktop app for Minecraft server management and sharing.",
  "main": "src/main/index.js",
  "type": "module",
  "author": "VoxelPort",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/voxelport/voxelport.git"
  },
  "scripts": {
    "dev": "concurrently \"npm:dev:renderer\" \"npm:dev:electron\"",
    "dev:renderer": "vite --config vite.config.js",
    "dev:electron": "wait-on tcp:5173 && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .",
    "start": "electron .",
    "build:renderer": "vite build --config vite.config.js",
    "build": "npm run build:renderer && electron-builder",
    "relay:dev": "node relay-server/index.js"
  },
  "dependencies": {
    "axios": "^1.11.0",
    "electron-store": "^11.0.1",
    "lucide-react": "^0.553.0",
    "pidusage": "^4.0.1",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-router-dom": "^7.9.1",
    "socket.io-client": "^4.8.1",
    "ws": "^8.20.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^5.0.2",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.1",
    "cross-env": "^10.0.0",
    "electron": "^37.3.1",
    "electron-builder": "^26.0.12",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.13",
    "vite": "^7.1.2",
    "wait-on": "^8.0.5"
  }
}
